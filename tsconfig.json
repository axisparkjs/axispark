{
    "compilerOptions": {
        "target": "es2016",
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "removeComments": true,
        "module": "commonjs",
        "declaration": true,
        "noLib": false,
        "rootDir": "packages",
        "outDir": "lib",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "sourceMap": true,
        "allowJs": false,
        "strict": true,
        "noImplicitAny": true,
        "strictPropertyInitialization": false,
        "noImplicitThis": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "skipLibCheck": true,
        "paths": {
            "@axisparkjs/common": ["./packages/common/src"],
            "@axisparkjs/common/*": ["./packages/common/src/*"],
            "@axisparkjs/core": ["./packages/core/src"],
            "@axisparkjs/core/*": ["./packages/core/src/*"],
            "@axisparkjs/di": ["./packages/di/src"],
            "@axisparkjs/di/*": ["./packages/di/src/*"],
            "@axisparkjs/logger": ["./packages/logger/src"],
            "@axisparkjs/logger/*": ["./packages/logger/src/*"],
            "@axisparkjs/test": ["./packages/test/src"],
            "@axisparkjs/test/*": ["./packages/test/src/*"],
            "@axisparkjs/samples": ["./samples"],
            "@axisparkjs/samples/*": ["./samples/*"]
        },
        "types": ["node", "jest"]
    },
    "include": ["packages/**/*", "samples/**/*"],
    "exclude": ["node_modules", "lib", "**/jest.config.ts"]
}
