{
    "name": "@axisparkjs/axispark",
    "version": "0.0.1",
    "description": "AxiSpark.js - The Ultimate Node.js Framework",
    "author": "Pablo Gálvez Ortuño",
    "license": "ISC",
    "scripts": {
        "prettier:fix": "prettier --config .prettierrc.json '**/*.{ts,js,mjs,json,md,html,css,scss}' --write",
        "prettier": "turbo run prettier",
        "lint": "turbo run lint",
        "build": "turbo run build",
        "test:unit": "turbo run test:unit",
        "test:e2e": "export NODE_ENV=test && jest --config jest.e2e.config.ts",
        "ci:prettier": "turbo run prettier --affected",
        "ci:lint": "turbo run lint --affected",
        "ci:build": "turbo run build --affected",
        "ci:test:unit": "turbo run test:unit --affected",
        "ci:test:e2e": "export NODE_ENV=test && jest --config jest.e2e.config.ts",
        "ci:sonar": "turbo run sonar --affected",
        "cd:changeset": "changeset",
        "cd:version": "changeset version",
        "cd:publish": "changeset publish"
    },
    "engines": {
        "node": ">= 20"
    },
    "private": true,
    "packageManager": "npm@10.5.0",
    "workspaces": [
        "packages/*"
    ],
    "devDependencies": {
        "@changesets/cli": "^2.31.0",
        "@eslint/js": "^9.37.0",
        "@types/express": "^5.0.6",
        "@types/jest": "^30.0.0",
        "@types/node": "^24.13.2",
        "eslint": "^9.37.0",
        "globals": "^16.2.0",
        "jest": "^30.2.0",
        "prettier": "^3.6.2",
        "sonar-scanner": "^3.1.0",
        "ts-jest": "^29.4.11",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "tsx": "^4.23.0",
        "turbo": "^2.10.4",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.46.0"
    },
    "dependencies": {
        "express": "^5.2.1",
        "reflect-metadata": "^0.2.2"
    }
}
